---
import SiteLayout from '../layouts/SiteLayout.astro'
import {
  featureCards,
  heroBullets,
  howItWorks,
  privacyPoints,
  screenshots,
  secondaryFacts,
  siteMeta,
} from '../data/site'
---

<SiteLayout title={siteMeta.title} description={siteMeta.description} path="/">
  <section class="hero-section">
    <div class="container hero-grid">
      <div class="hero-copy">
        <p class="eyebrow">Nudging reminders, without the noise.</p>
        <h1>Keep reminders in view until you deal with them.</h1>
        <p class="hero-text">
          Petera is for reminders that do not need an exact alarm time. Add a reminder,
          choose when it should show up, and adjust it with simple controls.
        </p>
        <div class="hero-actions">
          <a class="button button-primary" href="#screens">See the screens</a>
          <a class="button button-secondary" href="privacy/">Privacy</a>
        </div>
        <ul class="hero-bullets" aria-label="Highlights">
          {heroBullets.map((item) => (
            <li>{item}</li>
          ))}
        </ul>
      </div>

      <div class="hero-shot">
        <img
          src="petera-main_screen.png"
          alt="Petera Home screen with Today, Upcoming, and Paused sections."
          width="1080"
          height="2424"
        />
      </div>
    </div>
  </section>

  <section class="section-block" id="features">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Features</p>
        <h2>Simple reminder tools, clear controls.</h2>
      </div>
      <div class="card-grid">
        {featureCards.map((card) => (
          <article class="feature-card">
            <h3>{card.title}</h3>
            <p>{card.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block section-tinted" id="screens">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">Screens</p>
        <h2>Simple, clear, and focused on what matters.</h2>
      </div>
      <div class="screen-grid">
        {screenshots.map((screen) => (
          <article class="screen-card">
            <img
              class="screen-image"
              src={screen.src}
              alt={screen.alt}
              width="1080"
              height="2424"
              loading="lazy"
            />
            <div class="screen-copy">
              <h3>{screen.title}</h3>
              <p>{screen.body}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="container">
      <div class="section-heading">
        <p class="eyebrow">How it works</p>
        <h2>Three short steps.</h2>
      </div>
      <div class="step-grid">
        {howItWorks.map((step, index) => (
          <article class="step-card">
            <p class="step-number">0{index + 1}</p>
            <h3>{step.title}</h3>
            <p>{step.body}</p>
          </article>
        ))}
      </div>
    </div>
  </section>

  <section class="section-block">
    <div class="container detail-grid">
      <div class="detail-panel detail-panel-strong">
        <p class="eyebrow">Privacy</p>
        <h2>Your reminder data stays on your device by default.</h2>
        <ul class="plain-list">
          {privacyPoints.map((point) => (
            <li>{point}</li>
          ))}
        </ul>
        <a class="text-link" href="privacy/">Read the privacy page</a>
      </div>
      <div class="detail-panel">
        <p class="eyebrow">At a glance</p>
        <div class="fact-list">
          {secondaryFacts.map((fact) => (
            <div class="fact-row">
              <span>{fact.label}</span>
              <strong>{fact.value}</strong>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>
</SiteLayout>
