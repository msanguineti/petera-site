---
import SiteLayout from '../layouts/SiteLayout.astro'

const homeHref = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
---

<SiteLayout
  title="Privacy"
  description="Petera stores reminders on your device by default."
  path="/privacy/"
>
  <section class="section-block">
    <div class="container prose-shell">
      <p class="eyebrow">Privacy</p>
      <h1 class="page-title">Petera stores reminders on your device by default.</h1>
      <p class="page-intro">
        Your data leaves the device only if you choose to export it.
      </p>

      <div class="prose-card">
        <h2>On-device storage</h2>
        <ul class="plain-list">
          <li>Reminder data is stored on your device.</li>
          <li>Saved settings stay on your device unless you replace them with an import.</li>
          <li>Privacy and data controls are available in Settings.</li>
        </ul>
      </div>

      <div class="prose-card">
        <h2>Insights and suggestions</h2>
        <ul class="plain-list">
          <li>Insights and suggestions are processed on-device.</li>
        </ul>
      </div>

      <div class="prose-card">
        <h2>Export and restore</h2>
        <p>
          You can export your data from Settings and restore it later. Export and restore
          are manual actions.
        </p>
      </div>

      <div class="prose-actions">
        <a class="button button-primary" href={homeHref}>Back to home</a>
      </div>
    </div>
  </section>
</SiteLayout>
