---
import Layout from '../layouts/Layout.astro';
import FAQBento from '../components/FAQBento.astro';
import { siteConfig } from '../config/site';

const supportEmail = siteConfig.supportEmail;

const faqs = [
	{
		question: 'What is Petera?',
		answer:
			'Petera is a lightweight reminder app that brings things back to your attention over time. It is for reminders you want to keep seeing again, not a full task-management system.'
	},
	{
		question: 'What is Petera not meant to replace?',
		answer:
			'Petera is not intended to replace your calendar, a team project manager, or a full task hub. It is a focused reminder tool.'
	},
	{
		question: 'How do reminders work?',
		answer:
			'You set a reminder, and Petera brings it back through notifications over time. Depending on how you configure it, that can mean daily reminders, reminders several times a day, or slower repeating reminders.'
	},
	{
		question: 'Does Petera use exact-time alarms?',
		answer:
			'Petera is not built around a single alarm that fires once and disappears. The core idea is that reminders can return over time until they are dealt with.'
	},
	{
		question: 'Why does Petera need notification permission?',
		answer:
			'Petera uses notifications to surface reminders when you are not already in the app. Without notification permission, it is much harder for the app to keep bringing reminders back to your attention.'
	},
	{
		question: 'Is my data stored locally?',
		answer:
			'The current product direction is local-first. Reminder data stays on device unless you explicitly export it.'
	},
	{
		question: 'Does Petera sync between devices?',
		answer:
			'The current app direction is local-first and does not currently center on sync. If that changes later, the website and privacy materials should be updated.'
	},
	{
		question: 'Can I export my data?',
		answer: 'Yes. Petera currently supports manual local export and import under Settings > Data.'
	},
	{
		question: 'Is export encrypted?',
		answer:
			'Encrypted export is the default path in the current version. Users choose the password used for encrypted export.'
	},
	{
		question: 'What happens when I import data?',
		answer:
			'The current import flow is replace-only. It is designed to replace local reminder data and supported saved settings on the device rather than merge multiple reminder sets together.'
	},
	{
		question: 'What are History and Insights?',
		answer:
			'History and Insights are optional features. History is a record of user-meaningful reminder events and is off by default. Insights are local-only reminder activity summaries and are also off by default.'
	},
	{
		question: 'How do I report a bug?',
		answer:
			`Email ${supportEmail} and include: device model, OS version, app version, a clear description of the issue, steps to reproduce it, and screenshots if relevant.`
	},
	{
		question: 'How do I request support?',
		answer: `For general help, questions, or feedback, use ${supportEmail}.`
	}
];
---

<Layout title="Support" description="Support details, bug-report guidance, and FAQ for Petera.">
	<section class="article">
		<div class="shell">
			<h1>Support</h1>
			<p class="copy">
				This page brings together contact details, bug-report guidance, and answers to common
				questions about Petera.
			</p>

			<div class="intro-note copy">
				<p>
					If something is not working as expected, send a short report with the basics.
				</p>
			</div>

			<div class="surface support-contact">
				<h2 class="support-contact-title">Contact</h2>
				<p>
					Support email:
					<a href={`mailto:${supportEmail}`}><span class="code-like">{supportEmail}</span></a>
				</p>
				<p>When reporting a bug, please include:</p>
				<ul class="page-list">
					<li>Device model</li>
					<li>Operating system version</li>
					<li>App version</li>
					<li>What you expected to happen</li>
					<li>What happened instead</li>
					<li>Whether notifications were enabled</li>
				</ul>
				<p class="muted support-contact-note">
					We may not reply immediately, but detailed bug reports are much easier to investigate.
				</p>
			</div>

			<h2>Frequently Asked Questions</h2>
			<FAQBento items={faqs} />

			<p class="copy muted support-footer-note">
				If you are writing about a problem, concrete details make it much easier to investigate.
			</p>
		</div>
	</section>
</Layout>

<style>
	.support-contact {
		padding: clamp(1rem, 3vw, 1.5rem);
		margin-top: 1.2rem;
	}

	.support-contact-title {
		margin-top: 0;
	}

	.support-contact-note,
	.support-footer-note {
		margin-bottom: 0;
	}

	.support-contact-note {
		margin-top: 1rem;
	}

	.support-footer-note {
		margin-top: 1.5rem;
	}
</style>
