---
import SiteLayout from '../layouts/SiteLayout.astro'

const homeHref = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
---

<SiteLayout
  title="Not found"
  description="The page you requested was not found on the Petera site."
  path="/404/"
>
  <section class="section-block">
    <div class="container prose-shell compact-shell">
      <p class="eyebrow">404</p>
      <h1 class="page-title">This page does not exist.</h1>
      <p class="page-intro">
        The link may be outdated, or the page may have moved.
      </p>
      <div class="prose-actions">
        <a class="button button-primary" href={homeHref}>Go back home</a>
      </div>
    </div>
  </section>
</SiteLayout>
