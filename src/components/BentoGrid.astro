---
/**
 * BentoGrid Component
 * True asymmetrical bento grid layout with varied item sizes
 * 
 * @usage
 * <BentoGrid items={[
 *   { id: '1', title: 'Item 1', content: 'Description', colSpan: 1, rowSpan: 1 },
 *   { id: '2', title: 'Item 2', content: 'Description', colSpan: 2, rowSpan: 1 },
 *   { id: '3', title: 'Item 3', content: 'Description', colSpan: 1, rowSpan: 2 },
 * ]} />
 */

interface BentoItem {
  id: string;
  title: string;
  content: string;
  eyebrow?: string;
  note?: string;
  className?: string;
  colSpan?: 1 | 2 | 3; // Columns this item spans
  rowSpan?: 1 | 2; // Rows this item spans (1 or 2)
}

interface Props {
  items: BentoItem[];
  className?: string;
}

const { items, className = '' } = Astro.props;
---

<div class={`bento-grid ${className}`}>
  {items.map((item) => {
    const isHeroIcon = item.className?.includes('hero-icon-box');
    const isCTABox = item.className?.includes('cta-box');
    const isFooterLinks = item.className?.includes('footer-links-box');

    return (
      <article 
        class={`bento-item ${item.className || ''}`}
        style={{
          gridColumn: item.colSpan === 2 ? 'span 2' : item.colSpan === 3 ? 'span 3' : 'span 1',
          gridRow: item.rowSpan === 2 ? 'span 2' : 'span 1'
        }}
      >
        {isHeroIcon ? (
          <div class="bento-icon-content">
            <img src="/assets/petera-foreground.svg" alt="Petera icon" class="bento-flower" />
          </div>
        ) : isCTABox ? (
          <div class="bento-cta-content">
            {item.eyebrow && <p class="bento-eyebrow">{item.eyebrow}</p>}
            <div class="bento-cta-header">
              {item.title && <h3>{item.title}</h3>}
              {item.content && <p class="bento-cta-copy">{item.content}</p>}
            </div>
            <div class="cta-buttons-row">
              <a href="/support" class="button-primary">Get Support</a>
              <a href="/privacy" class="button-secondary">Read Privacy</a>
            </div>
          </div>
        ) : isFooterLinks ? (
          <div class="bento-footer-content">
            {item.eyebrow && <p class="bento-eyebrow">{item.eyebrow}</p>}
            {item.title && <h3>{item.title}</h3>}
            {item.content && <p class="bento-footer-copy">{item.content}</p>}
            <div class="footer-links">
              <a href="/privacy">Privacy</a>
              <a href="/support">Support</a>
              <a href="/terms">Terms</a>
            </div>
          </div>
        ) : (
          <div class="bento-content">
            {item.eyebrow && <p class="bento-eyebrow">{item.eyebrow}</p>}
            {item.title && <h3>{item.title}</h3>}
            {item.content && <p>{item.content}</p>}
            {item.note && <p class="bento-note">{item.note}</p>}
          </div>
        )}
      </article>
    );
  })}
</div>

<style>
  .bento-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 3vw, 1.5rem);
    grid-auto-flow: dense;
  }

  /* Mobile: Single column, all items span 1 */
  @media (max-width: 639px) {
    .bento-grid {
      grid-template-columns: 1fr;
    }

    .bento-item {
      grid-column: span 1 !important;
      grid-row: span 1 !important;
    }
  }

  /* Tablet: 2 columns with asymmetrical layout */
  @media (min-width: 640px) {
    .bento-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(1.25rem, 3vw, 1.5rem);
    }
  }

  /* Desktop: 3 columns with full asymmetrical bento pattern */
  @media (min-width: 1024px) {
    .bento-grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 1.5rem;
    }
  }

  .bento-item {
    background: color-mix(in srgb, var(--petera-surface) 92%, white 8%);
    border: 1px solid var(--petera-border);
    border-radius: var(--petera-radius-lg);
    padding: clamp(1.25rem, 4vw, 2rem);
    box-shadow: 0 12px 26px rgba(31, 36, 52, 0.04);
    transition: all 220ms ease;
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    min-height: clamp(160px, 25vw, 280px);
  }

  /* Larger items (col-span-2) get more padding */
  .bento-item[style*="grid-column: span 2"] {
    min-height: clamp(160px, 22vw, 260px);
  }

  /* Tall items (row-span-2) get more vertical space */
  .bento-item[style*="grid-row: span 2"] {
    min-height: auto;
  }

  /* Touch-friendly hover/active states */
  @media (hover: hover) {
    .bento-item:hover {
      transform: translateY(-3px);
      box-shadow: 0 16px 40px rgba(31, 36, 52, 0.12);
      border-color: var(--petera-primary-light);
    }
  }

  @media (hover: none) {
    .bento-item:active {
      transform: translateY(-1px);
      box-shadow: 0 16px 34px rgba(31, 36, 52, 0.08);
    }
  }

  .bento-content {
    display: flex;
    flex-direction: column;
    gap: clamp(0.75rem, 2vw, 1rem);
    height: 100%;
  }

  .bento-eyebrow {
    margin: 0;
    font-size: 0.78rem;
    font-weight: 700;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--petera-primary-strong);
  }

  .bento-item h3 {
    margin: 0;
    font-size: clamp(1.15rem, 3vw, 1.4rem);
    line-height: 1.25;
    letter-spacing: -0.02em;
    color: var(--petera-text);
  }

  /* Larger items (col-span-2) get bigger titles */
  .bento-item[style*="grid-column: span 2"] h3 {
    font-size: clamp(1.3rem, 3.5vw, 1.6rem);
  }

  .bento-item p {
    margin: 0;
    font-size: clamp(0.9rem, 2vw, 0.95rem);
    line-height: 1.5;
    color: var(--petera-text-soft);
  }

  .bento-note {
    margin-top: auto;
    padding-top: 0.85rem;
    border-top: 1px solid rgba(201, 189, 175, 0.5);
    font-size: 0.82rem;
    line-height: 1.45;
    color: var(--petera-text-muted);
  }

  .bento-item ul {
    margin: 0;
    padding-left: clamp(1.25rem, 3vw, 1.5rem);
    list-style: disc;
  }

  .bento-item li {
    margin-bottom: clamp(0.35rem, 1vw, 0.5rem);
    color: var(--petera-text-soft);
    font-size: clamp(0.9rem, 2vw, 0.95rem);
    line-height: 1.5;
  }

  .bento-item li:last-child {
    margin-bottom: 0;
  }

  /* Special box styles */
  .hero-main-box {
    justify-content: center;
  }

  .hero-main-box h3 {
    font-size: clamp(1.6rem, 5vw, 2.2rem);
    line-height: 1.2;
    letter-spacing: -0.03em;
  }

  .hero-main-box p {
    font-size: clamp(1rem, 2.5vw, 1.15rem);
    line-height: 1.6;
  }

  .hero-icon-box {
    position: relative;
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
    isolation: isolate;
  }

  .bento-icon-content {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
  }

  .bento-flower {
    width: 190%;
    height: auto;
    max-width: none;
    filter: drop-shadow(0 12px 28px rgba(38, 51, 112, 0.18));
    animation: floatBento 6s ease-in-out infinite alternate;
    transform: translate(14%, 12%);
  }

  @keyframes floatBento {
    0% { transform: translateY(-8px) rotate(-0.5deg); }
    100% { transform: translateY(8px) rotate(0.5deg); }
  }

  .cta-box {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bento-cta-content {
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: stretch;
    justify-content: space-between;
    gap: 1.15rem;
    padding: 2rem;
    text-align: left;
  }

  .bento-cta-header {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
    max-width: 34rem;
  }

  .bento-cta-copy {
    max-width: 40ch;
  }

  .cta-buttons-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.9rem;
    align-items: center;
  }

  @media (hover: hover) {
    .cta-buttons-row a:hover {
      transform: translateY(-1px);
    }
  }

  .footer-links-box {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .bento-footer-content {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-direction: column;
    gap: 0.8rem;
    padding: 1.5rem;
    text-align: center;
  }

  .bento-footer-copy {
    max-width: 40ch;
  }

  .footer-links {
    display: flex;
    gap: 1.5rem;
    flex-wrap: wrap;
    justify-content: center;
  }

  .footer-links a {
    font-weight: 500;
  }

  /* Mobile optimizations */
  @media (max-width: 640px) {
    .bento-grid {
      grid-template-columns: 1fr;
      gap: clamp(1rem, 2.5vw, 1.25rem);
    }

    .bento-item {
      padding: clamp(1.1rem, 3.5vw, 1.5rem);
    }

    .bento-item.col-span-2 {
      grid-column: span 1;
    }

    .bento-flower {
      width: 145%;
      transform: translate(8%, 8%);
    }

    .bento-cta-content,
    .bento-footer-content {
      padding: 1.35rem;
    }

    .cta-buttons-row {
      flex-direction: column;
      align-items: stretch;
    }
  }
</style>
