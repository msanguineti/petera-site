---
/**
 * FAQBento Component
 * Interactive FAQ items in a bento-inspired layout
 * Items expand to show full answers
 */

interface FAQItem {
  question: string;
  answer: string;
  id?: string;
}

interface Props {
  items: FAQItem[];
  className?: string;
}

const { items, className = '' } = Astro.props;
---

<div class={`faq-bento ${className}`}>
  {items.map((item, index) => (
    <details class="faq-item" data-id={item.id || `faq-${index}`}>
      <summary class="faq-question">
        <span class="faq-q-num">{String(index + 1).padStart(2, '0')}</span>
        <h3>{item.question}</h3>
        <span class="faq-toggle" aria-hidden="true">+</span>
      </summary>
      <p class="faq-answer">{item.answer}</p>
    </details>
  ))}
</div>

<style>
  .faq-bento {
    display: grid;
    grid-template-columns: 1fr;
    gap: clamp(1rem, 2.5vw, 1.5rem);
  }

  /* Tablet: 2 columns */
  @media (min-width: 640px) {
    .faq-bento {
      grid-template-columns: repeat(2, 1fr);
      gap: clamp(1.25rem, 3vw, 1.5rem);
    }
  }

  /* Desktop: 2 columns with better spacing */
  @media (min-width: 1024px) {
    .faq-bento {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  .faq-item {
    background: color-mix(in srgb, var(--petera-surface) 92%, white 8%);
    border: 1px solid var(--petera-border);
    border-radius: var(--petera-radius-lg);
    overflow: hidden;
    transition: all 220ms ease;
  }

  @media (hover: hover) {
    .faq-item:hover {
      box-shadow: 0 12px 26px rgba(31, 36, 52, 0.04);
      border-color: var(--petera-border-strong);
    }
  }

  .faq-item[open] {
    box-shadow: 0 16px 34px rgba(31, 36, 52, 0.08);
    border-color: var(--petera-primary);
  }

  .faq-question {
    display: flex;
    align-items: flex-start;
    gap: clamp(0.75rem, 2vw, 1rem);
    padding: clamp(1.25rem, 3vw, 1.5rem);
    cursor: pointer;
    user-select: none;
    list-style: none;
    min-height: 3rem;
  }

  @media (hover: hover) {
    .faq-question:hover {
      background: rgba(123, 151, 248, 0.04);
    }
  }

  @media (hover: none) {
    .faq-question:active {
      background: rgba(123, 151, 248, 0.08);
    }
  }

  .faq-q-num {
    font-size: clamp(0.75rem, 2vw, 0.85rem);
    font-weight: 600;
    color: var(--petera-primary);
    min-width: clamp(1.75rem, 4vw, 2rem);
    text-align: center;
    flex-shrink: 0;
    margin-top: 0.15rem;
  }

  .faq-question h3 {
    margin: 0;
    font-size: clamp(1rem, 2.5vw, 1.1rem);
    line-height: 1.3;
    letter-spacing: -0.01em;
    flex: 1;
    text-align: left;
  }

  .faq-toggle {
    font-size: clamp(1.25rem, 3vw, 1.5rem);
    color: var(--petera-primary);
    font-weight: 300;
    transition: transform 200ms ease;
    flex-shrink: 0;
    margin-top: 0.1rem;
    display: flex;
    align-items: center;
    justify-content: center;
    min-width: 1.5rem;
    min-height: 1.5rem;
  }

  .faq-item[open] .faq-toggle {
    transform: rotate(45deg);
  }

  .faq-answer {
    padding: 0 clamp(1.1rem, 3vw, 1.5rem) clamp(1.1rem, 3vw, 1.5rem) clamp(3rem, 6vw, 3.5rem);
    margin: 0;
    line-height: 1.6;
    color: var(--petera-text-soft);
    font-size: clamp(0.9rem, 2vw, 0.95rem);
    animation: slideDown 200ms ease;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  /* Mobile optimizations */
  @media (max-width: 640px) {
    .faq-bento {
      grid-template-columns: 1fr;
      gap: clamp(0.9rem, 2vw, 1.2rem);
    }

    .faq-question {
      gap: 0.6rem;
      padding: clamp(1.1rem, 2.5vw, 1.35rem);
      min-height: 2.75rem;
    }

    .faq-q-num {
      min-width: 1.6rem;
    }

    .faq-question h3 {
      font-size: clamp(0.95rem, 2.2vw, 1rem);
    }

    .faq-toggle {
      font-size: 1.3rem;
      min-width: 1.3rem;
      min-height: 1.3rem;
    }

    .faq-answer {
      padding: 0 clamp(0.9rem, 2vw, 1.2rem) clamp(0.9rem, 2vw, 1.2rem) clamp(2.6rem, 5vw, 3rem);
      font-size: clamp(0.85rem, 1.8vw, 0.9rem);
    }
  }

  /* Extra small screens */
  @media (max-width: 380px) {
    .faq-question {
      flex-direction: column;
      gap: 0.5rem;
      padding: 1rem;
      align-items: flex-start;
    }

    .faq-q-num {
      margin-bottom: 0.25rem;
    }

    .faq-toggle {
      position: absolute;
      right: 1rem;
      top: 1rem;
    }

    .faq-question h3 {
      padding-right: 2rem;
    }
  }
</style>
