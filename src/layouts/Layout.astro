---
import '@fontsource/noto-sans/400.css';
import '@fontsource/noto-sans/500.css';
import '@fontsource/noto-sans/700.css';
import '@fontsource/noto-sans-display/300.css';
import '../styles/global.css';
import { siteConfig } from '../config/site';

interface Props {
	title: string;
	description?: string;
}

const { title, description = 'Petera is a reminder app that brings things back to your attention over time.' } = Astro.props;
const path = Astro.url.pathname;

function isConfigured(value: string, placeholder: string) {
	return value.trim() !== placeholder;
}

const pageTitle = title === 'Petera' ? title : `${title} | Petera`;
const hasSupportEmail = isConfigured(siteConfig.supportEmail, 'YOUR_CONTACT_EMAIL');
const hasOwnerEntity = isConfigured(siteConfig.ownerEntity, 'YOUR_NAME_OR_ENTITY');
const hasCopyrightYear = isConfigured(siteConfig.copyrightYear, 'YEAR');
const supportLabel = hasSupportEmail ? siteConfig.supportEmail : 'Support details';
const navItems = [
	{ href: '/', label: 'Home' },
	{ href: '/privacy', label: 'Privacy' },
	{ href: '/support', label: 'Support' },
	{ href: '/terms', label: 'Terms' }
];
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />
		<link rel="icon" type="image/svg+xml" href="/assets/brand-mark.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{pageTitle}</title>
		<meta name="description" content={description} />
		<meta property="og:title" content={pageTitle} />
		<meta property="og:description" content={description} />
		<meta property="og:type" content="website" />
		<meta property="og:image" content="/assets/petera-icon.svg" />
	</head>
	<body>
		<a class="skip-link" href="#content">Skip to content</a>
		<header class="site-header">
			<div class="shell header-inner">
				<a class="brand-link" href="/" aria-label="Petera home">
					<img src="/assets/petera-foreground.svg" alt="" width="32" height="32" />
					<span>Petera</span>
				</a>
				<nav aria-label="Primary">
					<ul class="nav-list">
						{
							navItems.map((item) => (
								<li>
									<a href={item.href} aria-current={path === item.href ? 'page' : undefined}>
										{item.label}
									</a>
								</li>
							))
						}
					</ul>
				</nav>
			</div>
		</header>

		<main id="content">
			<slot />
		</main>

		<footer class="site-footer section">
			<div class="shell footer-grid">
				<div class="copy">
					<p class="footer-title">Petera</p>
					<p>Support, privacy, terms, and store links in one place.</p>
				</div>
				<div>
					<p class="footer-title">Pages</p>
					<ul class="footer-links">
						<li><a href="/">Home</a></li>
						<li><a href="/privacy">Privacy</a></li>
						<li><a href="/support">Support</a></li>
						<li><a href="/terms">Terms</a></li>
					</ul>
				</div>
				<div>
					<p class="footer-title">Contact</p>
					<p>
						<a href={hasSupportEmail ? `mailto:${siteConfig.supportEmail}` : '/support'}>{supportLabel}</a>
					</p>
					<p class="small-note">
						{hasCopyrightYear ? `Copyright ${siteConfig.copyrightYear}` : 'Copyright details pending'}
						{hasOwnerEntity ? ` ${siteConfig.ownerEntity}` : ''}
					</p>
				</div>
			</div>
		</footer>
	</body>
</html>
