---
import '../styles/global.css'
import { navLinks, siteMeta } from '../data/site'

type Props = {
  title?: string
  description?: string
  path?: string
}

const {
  title = siteMeta.title,
  description = siteMeta.description,
  path = '/',
} = Astro.props

const pageTitle = title === siteMeta.title ? title : `${title} | ${siteMeta.title}`
const basePath = import.meta.env.BASE_URL.endsWith('/')
  ? import.meta.env.BASE_URL
  : `${import.meta.env.BASE_URL}/`
const origin = Astro.site ? new URL(basePath, Astro.site) : new URL(basePath, Astro.url)
const canonical = new URL(path.replace(/^\//, ''), origin).toString()
const socialImage = new URL('social-card.svg', origin).toString()
const hrefFromBase = (href: string) => `${basePath}${href.replace(/^\//, '')}`
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#F4F1EA" />
    <link rel="canonical" href={canonical} />
    <link rel="icon" type="image/svg+xml" href={hrefFromBase('petera-icon.svg')} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin="anonymous" />
    <link
      href="https://fonts.googleapis.com/css2?family=Noto+Sans:wght@400;500;600;700&family=Noto+Sans+Display:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={socialImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImage} />
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <div class="container header-row">
          <a class="brand" href={basePath}>
            <img
              class="brand-mark"
              src={hrefFromBase('petera-icon.svg')}
              alt=""
              width="40"
              height="40"
            />
            <span>Petera</span>
          </a>
          <nav class="site-nav" aria-label="Primary">
            {navLinks.map((link) => (
              <a href={hrefFromBase(link.href)}>{link.label}</a>
            ))}
          </nav>
        </div>
      </header>
      <main>
        <slot />
      </main>
      <footer class="site-footer">
        <div class="container footer-row">
          <div>
            <p class="footer-title">Petera</p>
            <p class="footer-copy">
              Simple reminders with clear controls.
            </p>
          </div>
          <div class="footer-links" aria-label="Footer">
            <a href={hrefFromBase('/#features')}>Features</a>
            <a href={hrefFromBase('/#screens')}>Screens</a>
            <a href={hrefFromBase('/privacy/')}>Privacy</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>
